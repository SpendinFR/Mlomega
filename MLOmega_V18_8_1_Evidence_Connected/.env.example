# MemoryLight Omega Audio Elite V3 RTX 3070
MLOMEGA_HOME=.mlomega_audio_elite
MLOMEGA_STRICT_ELITE=true

# Audio GPU
MLOMEGA_ENABLE_WHISPERX=true
MLOMEGA_ENABLE_PYANNOTE=true
MLOMEGA_ENABLE_SPEECHBRAIN=true
MLOMEGA_HF_TOKEN=YOUR_HUGGINGFACE_TOKEN_ACCEPT_PYANNOTE_MODELS
MLOMEGA_WHISPERX_MODEL=large-v3
MLOMEGA_WHISPERX_DEVICE=cuda
MLOMEGA_WHISPERX_COMPUTE_TYPE=float16
MLOMEGA_WHISPERX_BATCH_SIZE=8
MLOMEGA_VOICE_THRESHOLD=0.72

# Vector memory
MLOMEGA_VECTOR_BACKEND=qdrant
MLOMEGA_QDRANT_URL=http://localhost:6333
MLOMEGA_QDRANT_COLLECTION=mlomega_audio_memory
# V17 predictive cases use a dedicated collection on the SAME Qdrant instance.
# Do not point this at a generic chunk collection with another embedding model.
MLOMEGA_V17_QDRANT_COLLECTION=mlomega_audio_memory_v17_cases
MLOMEGA_V17_EMBEDDING_REVISION=v18-rc5-predictive-1
MLOMEGA_V17_DENSE_CANDIDATE_LIMIT=80
MLOMEGA_V17_RERANK_CANDIDATE_LIMIT=30
MLOMEGA_V17_CALIBRATION_MIN_SAMPLES=30
MLOMEGA_V17_CALIBRATION_MIN_VALIDATION_PRECISION=0.60
# MLOMEGA_QDRANT_API_KEY=...
MLOMEGA_EMBEDDING_BACKEND=sentence_transformers
MLOMEGA_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
MLOMEGA_RERANKER_BACKEND=sentence_transformers
MLOMEGA_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Graphiti / Neo4j
MLOMEGA_GRAPH_BACKEND=graphiti
MLOMEGA_GRAPHITI_URI=bolt://localhost:7687
MLOMEGA_GRAPHITI_USER=neo4j
MLOMEGA_GRAPHITI_PASSWORD=mlomega-password
NEO4J_AUTH=neo4j/mlomega-password

# Local LLM deep reasoning via Ollama
MLOMEGA_ENABLE_OLLAMA=true
MLOMEGA_ENABLE_LLM_DEEP=true
MLOMEGA_OLLAMA_BASE_URL=http://localhost:11434
MLOMEGA_OLLAMA_MODEL=qwen3:8b

# Mem0 local branché à Ollama + Qdrant (pas de provider cloud)
MLOMEGA_MEM0_ENABLED=true
MLOMEGA_MEM0_LLM_PROVIDER=ollama
MLOMEGA_MEM0_LLM_MODEL=qwen3:8b
MLOMEGA_MEM0_LLM_TEMPERATURE=0.1
MLOMEGA_MEM0_LLM_MAX_TOKENS=2000
MLOMEGA_MEM0_EMBEDDER_PROVIDER=ollama
MLOMEGA_MEM0_EMBEDDER_MODEL=nomic-embed-text
MLOMEGA_MEM0_EMBEDDING_DIMS=768
MLOMEGA_MEM0_VECTOR_STORE=qdrant
MLOMEGA_MEM0_QDRANT_URL=http://localhost:6333
MLOMEGA_MEM0_QDRANT_COLLECTION=mlomega_mem0

# V13.3 self voice + direct 24/24 flow
MLOMEGA_REQUIRE_SELF_VOICE=true
MLOMEGA_VOICE_LEARNING_STRICT=true

# V18 release safety: keep false in production. True is diagnostic-only and
# makes `mlomega-audio v18-release-audit --strict --fail` fail.
MLOMEGA_ALLOW_LEGACY_IMPLICIT_OWNER=false
