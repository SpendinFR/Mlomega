# Copie ce fichier vers ~/mlomega_android_config.env puis modifie API_BASE et TOKEN.

# PC via Tailscale, ex: http://100.64.12.34:8766
API_BASE="http://IP_TAILSCALE_DU_PC:8766"
TOKEN="TON_GROS_SECRET"
# Identité stable du téléphone pour les source_event_id. Ne pas la changer entre
# les retries : elle permet au PC de reconnaître une même capture réseau.
MLOMEGA_DEVICE_ID="android_phone"

# Cadence V18.8 BrainLive
AUDIO_SECONDS=4        # 3 à 5 secondes. 4 = bon compromis live.
IMAGE_SECONDS=25       # image toutes les 20-30 secondes: assez pour contexte/VLM sans bloquer l'audio.
GPS_SECONDS=30         # GPS plus fréquent pour lier audio/image/lieu.

# AUDIO = priorité qualité.  Objectif: WAV 16k mono PCM pour Whisper/SpeechBrain.
# Attention: certaines versions Termux:API ne produisent pas de vrai WAV/PCM via MediaRecorder.
# Le script tente le WAV et vérifie l'en-tête RIFF/WAVE. Si indisponible, fallback AAC haute qualité
# sauf si AUDIO_REQUIRE_WAV=1.
AUDIO_FORMAT=wav
AUDIO_WAV_ENCODER=wav
AUDIO_REQUIRE_WAV=0          # 1 = refuse le fallback si le téléphone ne sait pas produire WAV.
AUDIO_FALLBACK_ENCODER=aac
AUDIO_FALLBACK_BITRATE_KBPS=256
AUDIO_BITRATE_KBPS=256
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_SETTLE_SECONDS=0.25
AUDIO_MIN_BYTES=12000

# IMAGE = priorité compréhension scène.  On compresse intelligemment, pas trop.
# 1600px / JPEG 88 est un bon compromis pour Moondream live + VLM Brain2 le soir.
IMAGE_OPTIMIZE=1
IMAGE_MAX_DIM=1600
IMAGE_JPEG_QUALITY=88
IMAGE_MIN_BYTES=10000

# Garde-fous stockage: si le PC/réseau coupe, on protège le téléphone.
# Les fichiers envoyés sont supprimés si KEEP_SENT_FILES=0. Ces limites concernent seulement le backlog.
MIN_FREE_MB_FOR_IMAGES=2048
MIN_FREE_MB_FOR_AUDIO=512
MAX_IMAGE_PENDING=500
MAX_AUDIO_PENDING=8000

ENABLE_AUDIO=1
ENABLE_IMAGES=1
ENABLE_GPS=1

# Camera: souvent 0=arrière, 1=avant. Vérifie avec termux-camera-info.
CAMERA_ID=0

# Adresse lisible type "boulangerie / rue / commerce".
# 0 = pas de reverse geocode externe, juste lat/lon + maps_url.
# 1 = reverse geocode via OpenStreetMap/Nominatim; utile mais dépend d'Internet externe.
REVERSE_GEOCODE=0
ADDRESS_SECONDS=300
ADDRESS_MIN_MOVE_METERS=80

# Envoi: capture et upload sont séparés. L'uploader audio est prioritaire.
UPLOAD_SLEEP_SECONDS=1
CURL_CONNECT_TIMEOUT=8
CURL_MAX_TIME=120
CURL_RETRY=2
CURL_RETRY_DELAY=2

# Stop: quand tu arrêtes Android, on appelle /session/stop sur le PC.
POST_SESSION_STOP=1

# Conservation locale après upload réussi.
KEEP_SENT_FILES=0
MAX_FAILED_KEEP=2000

# Uploaders séparés: l'audio ne doit jamais attendre les images.
AUDIO_UPLOAD_SLEEP_SECONDS=0.15
GPS_UPLOAD_SLEEP_SECONDS=0.5
IMAGE_UPLOAD_SLEEP_SECONDS=1
FAST_CURL_CONNECT_TIMEOUT=5
AUDIO_CURL_MAX_TIME=45
IMAGE_CURL_MAX_TIME=180

# Stop propre: on stoppe la capture puis on laisse les uploaders vider le backlog
# avant de demander au PC de lancer post-stop / Brain2.
DRAIN_UPLOADS_ON_STOP=1
DRAIN_UPLOADS_TIMEOUT_SECONDS=180
