# Generated by INSTALL_MLOMEGA_V18_6_WINDOWS.ps1. Do not put this file in Git.
MLOMEGA_DEPLOYMENT_PROFILE=CORE_BRAINLIVE_V18_6_PHONE
MLOMEGA_GRAPH_BACKEND=disabled
MLOMEGA_MEM0_ENABLED=false
MLOMEGA_STRICT_ELITE=true

# Paths are written by the installer as absolute Windows paths.
MLOMEGA_HOME=__PROJECT_ROOT__\.mlomega_audio_elite
MLOMEGA_DB=__PROJECT_ROOT__\.mlomega_audio_elite\memory.db
MLOMEGA_RAW=__PROJECT_ROOT__\.mlomega_audio_elite\raw
MLOMEGA_PROJECT_ROOT=__PROJECT_ROOT__

# Local services
MLOMEGA_QDRANT_URL=http://127.0.0.1:6333
MLOMEGA_OLLAMA_BASE_URL=http://127.0.0.1:11434
MLOMEGA_ENABLE_OLLAMA=true
MLOMEGA_OLLAMA_MODEL=qwen3.5:9b
MLOMEGA_VLM_MODEL=moondream
MLOMEGA_OFFLINE_VLM_MODEL=qwen3-vl:8b
MLOMEGA_VLM_HEAVY_MODEL=qwen3-vl:8b
MLOMEGA_OLLAMA_KEEP_ALIVE_LIVE=20m
MLOMEGA_OLLAMA_KEEP_ALIVE_POSTSTOP=30m
MLOMEGA_OLLAMA_CONNECT_TIMEOUT_S=45
MLOMEGA_OLLAMA_COLD_START_TIMEOUT_S=900

# Live remains lightweight; deep post-stop uses WhisperX large-v3.
MLOMEGA_BRAINLIVE_ASR_BACKEND=faster_or_whispercpp
MLOMEGA_FAST_WHISPER_MODEL=small
MLOMEGA_FAST_WHISPER_DEVICE=cuda
MLOMEGA_FAST_WHISPER_COMPUTE=float16
MLOMEGA_WHISPERX_MODEL=large-v3
MLOMEGA_WHISPERX_DEVICE=cuda
MLOMEGA_WHISPERX_COMPUTE_TYPE=float16
MLOMEGA_WHISPERX_BATCH_SIZE=4
MLOMEGA_ENABLE_WHISPERX=true
MLOMEGA_ENABLE_PYANNOTE=true
MLOMEGA_ENABLE_SPEECHBRAIN=true
MLOMEGA_HF_TOKEN=__HF_TOKEN__

# Deep/post-stop reliability. A timeout is retried and retained as a resumable checkpoint.
MLOMEGA_POSTSTOP_LLM_TIMEOUT_S=900
MLOMEGA_POSTSTOP_VLM_TIMEOUT_S=300
MLOMEGA_POSTSTOP_RETRY_MAX=2
MLOMEGA_POSTSTOP_RETRY_BACKOFF_S=15,60
MLOMEGA_DEEP_AUDIO_RETRY_MAX=2
MLOMEGA_DEEP_AUDIO_FFMPEG_TIMEOUT_S=300
MLOMEGA_DEEP_AUDIO_BUNDLE_MAX_SECONDS=1800
MLOMEGA_STAGE_STALE_AFTER_S=1800
MLOMEGA_STOP_DRAIN_TIMEOUT_S=300
MLOMEGA_STOP_DRAIN_IDLE_PASSES=2
MLOMEGA_CLEANUP_REQUIRES_ZERO_PENDING=true

# Phone Bridge; token is generated automatically by installer.
MLOMEGA_PHONE_BRIDGE_URL=http://127.0.0.1:8766
MLOMEGA_PHONE_BRIDGE_REQUIRED=true
MLOMEGA_PHONE_TOKEN=__PHONE_TOKEN__
MLOMEGA_PHONE_DRAIN_BEFORE_POST_STOP=1
MLOMEGA_PHONE_DRAIN_TIMEOUT_S=300
MLOMEGA_PHONE_CLEANUP_AFTER_POST_STOP=1
MLOMEGA_CLOSE_DAY_TIMEOUT_S=7200
MLOMEGA_CLOSE_DAY_POLL_S=2

# Speaker enrollment is optional at bootstrap. Unknown speakers are preserved as pending clusters.
MLOMEGA_REQUIRE_SELF_VOICE=false
MLOMEGA_VOICE_LEARNING_STRICT=true
MLOMEGA_VOICE_THRESHOLD=0.72
